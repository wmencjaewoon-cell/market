{
  "expo": {
    "name": "interior-market",
    "slug": "interior-market",
    "version": "1.1.4",
    "orientation": "portrait",
    "icon": "./assets/images/interior-market.jpg",
    "scheme": "interiormarket",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.interiormarket",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "영상통화를 위해 카메라 사용 권한이 필요합니다.",
        "NSMicrophoneUsageDescription": "보이스톡과 영상통화를 위해 마이크 사용 권한이 필요합니다."
      },
      "bitcode": false,
      "appleTeamId": "T2PH62KS5U"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "여기에_기존_GOOGLE_MAPS_API_KEY"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.interiormarket"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/interior-market.jpg"
    },
    "plugins": [
  "expo-router",
  "expo-notifications",
  "expo-apple-authentication",
  [
    "expo-splash-screen",
    {
      "image": "./assets/images/splash-icon.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#000000"
      }
    }
  ],
  "expo-web-browser",
  "expo-secure-store",
  "@config-plugins/react-native-webrtc"
],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "04729bbb-3cc4-460b-a9f3-007ae34c5297"
      }
    }
  }
}

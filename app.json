{
  "expo": {
    "name": "interior-market",
    "slug": "interior-market",
    "version": "1.1.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "interiormarket",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.interiormarket",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "영상통화를 위해 카메라 사용 권한이 필요합니다.",
        "NSMicrophoneUsageDescription": "보이스톡과 영상통화를 위해 마이크 사용 권한이 필요합니다."
      },
      "bitcode": false,
      "appleTeamId": "T2PH62KS5U"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "여기에_기존_GOOGLE_MAPS_API_KEY"
        }
      },
      "adaptiveIcon": {
  "backgroundColor": "#ffffff",
  "foregroundImage": "./assets/images/interior-market.jpg"
},
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.interiormarket"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    }
  }
}